# Hub process
HUB_HOST=0.0.0.0
HUB_PORT=3737
HUB_PUBLIC_URL=http://192.168.1.20:3737
HUB_DATABASE_PATH=./data/hub.sqlite
HUB_BACKUP_DIR=./data/backups
HUB_PRINTER_DRY_RUN=true
HUB_ADMIN_TOKEN=replace-with-a-long-random-token

# Convex cloud sync bridge
CONVEX_HTTP_URL=
CONVEX_DEPLOY_KEY=
POS_SYNC_SECRET=
POS_INSTALLATION_ID=

# Cloud admin app: WorkOS AuthKit + Convex
# Put real local values in .env.local, not here.
# Generate cookie password with: openssl rand -base64 24

NEXT_PUBLIC_CONVEX_URL=
