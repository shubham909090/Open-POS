{
  "name": "@gaurav-pos/hub-electron",
  "version": "0.1.4",
  "description": "Offline-first restaurant POS hub for Windows.",
  "author": "Gaurav POS",
  "private": true,
  "type": "module",
  "main": "dist/electron.js",
  "scripts": {
    "build": "pnpm --filter @gaurav-pos/shared build && vite build && tsc -p tsconfig.build.json",
    "build:renderer": "pnpm --filter @gaurav-pos/shared build && vite build --mode development",
    "dev": "pnpm build:renderer && dotenv -e ../../.env.local -- tsx src/main.ts",
    "dev:desktop": "pnpm build:renderer && dotenv -e ../../.env.local -- electron --no-sandbox --import tsx src/electron.ts",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "package:win": "pnpm build && electron-builder --win nsis --x64",
    "package:update": "tsx scripts/create-update-package.ts",
    "package:dir": "pnpm build && electron-builder --dir",
    "lint": "pnpm --filter @gaurav-pos/shared build && tsc --noEmit",
    "perf:load": "pnpm --filter @gaurav-pos/shared build && tsx scripts/hub-load-probe.ts",
    "test": "vitest run",
    "typecheck": "pnpm --filter @gaurav-pos/shared build && tsc --noEmit"
  },
  "dependencies": {
    "@fastify/merge-json-schemas": "0.2.1",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.0.1",
    "@gaurav-pos/shared": "workspace:*",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.100.9",
    "adm-zip": "^0.5.17",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dequal": "2.0.3",
    "drizzle-orm": "^0.45.2",
    "fast-json-stringify": "6.4.0",
    "fast-uri": "3.1.2",
    "fastify": "^5.3.3",
    "json-schema-ref-resolver": "3.0.0",
    "lucide-react": "^1.14.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rfdc": "1.4.1",
    "tailwind-merge": "^3.6.0",
    "wrappy": "^1.0.2",
    "zod": "^3.24.4",
    "zustand": "^5.0.13",
    "7zip-bin": "5.2.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^38.8.6",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.8.3",
    "vite": "^8.0.11",
    "vitest": "^3.1.3",
    "ws": "^8.20.1"
  },
  "build": {
    "appId": "in.gaurav.pos.hub",
    "productName": "Gaurav POS Hub",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "drizzle/**/*",
      "preload.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/hub.env.example",
        "to": "hub.env.example"
      }
    ],
    "asarUnpack": [
      "**/*.node",
      "**/7zip-bin/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "identity": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Gaurav POS Hub"
    }
  }
}
