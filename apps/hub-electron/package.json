{
  "name": "@gaurav-pos/hub-electron",
  "version": "0.1.0",
  "description": "Offline-first restaurant POS hub for Windows.",
  "author": "Gaurav POS",
  "private": true,
  "type": "module",
  "main": "dist/electron.js",
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "build:renderer": "vite build --mode development",
    "dev": "pnpm build:renderer && dotenv -e ../../.env.local -- tsx src/main.ts",
    "dev:desktop": "pnpm build:renderer && dotenv -e ../../.env.local -- electron --no-sandbox --import tsx src/electron.ts",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "package:win": "pnpm build && electron-builder --win nsis --x64",
    "package:dir": "pnpm build && electron-builder --dir",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.0.1",
    "@gaurav-pos/shared": "workspace:*",
    "@tanstack/react-query": "^5.100.9",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.3.3",
    "lucide-react": "^1.14.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^3.24.4",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^38.8.6",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.3",
    "vite": "^8.0.11",
    "vitest": "^3.1.3"
  },
  "build": {
    "appId": "in.gaurav.pos.hub",
    "productName": "Gaurav POS Hub",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "drizzle/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/hub.env.example",
        "to": "hub.env.example"
      }
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "identity": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Gaurav POS Hub"
    }
  }
}
