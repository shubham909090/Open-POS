# Optional developer/recovery fallback only.
# Normal restaurant setup is done inside Hub → Setup → Hub Connection And Security.
#
# If support needs a file fallback, copy this file to one of these Windows locations:
# C:\ProgramData\Gaurav POS Hub\hub.env
# %APPDATA%\Gaurav POS Hub\hub.env

HUB_HOST=0.0.0.0
HUB_PORT=3737

# Optional. Leave these unset for normal installs; the hub uses the OS app-data
# folder by default.
# HUB_DATABASE_PATH=C:\ProgramData\Gaurav POS Hub\data\hub.sqlite
# HUB_BACKUP_DIR=C:\ProgramData\Gaurav POS Hub\backups

# Fresh hubs start in Printer Test Mode. Switch to Live Mode inside Hub Setup
# after selecting printers and running test prints.

# Cloud URL, hub connection ID, sync secret, and hub public URL are saved in
# the Hub UI. Keep these env fallbacks blank unless support asks for them.
# HUB_PUBLIC_URL=http://192.168.1.20:3737
# CONVEX_HTTP_URL=https://your-convex-site.convex.site
# POS_INSTALLATION_ID=paste-from-cloud-portal
# POS_SYNC_SECRET=paste-from-cloud-portal
