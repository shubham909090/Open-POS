{
  "expo": {
    "name": "Gaurav POS Mobile",
    "slug": "gaurav-pos-mobile",
    "version": "0.1.8",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Gaurav POS to scan hub pairing QR codes."
        }
      ],
      "./plugins/with-cleartext-traffic.cjs"
    ],
    "android": {
      "package": "com.gauravpos.mobile",
      "versionCode": 8,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "253e6cd4-439c-4f52-bff4-f3a03e298621"
      }
    }
  }
}
