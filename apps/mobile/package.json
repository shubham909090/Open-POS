{
  "name": "@gaurav-pos/mobile",
  "version": "0.1.6",
  "private": true,
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build:shared": "pnpm --filter @gaurav-pos/shared build",
    "dev": "pnpm build:shared && expo start",
    "android": "pnpm build:shared && expo start --android",
    "android:prebuild": "expo prebuild --platform android",
    "android:apk": "pnpm dlx eas-cli@18.11.0 build --platform android --profile preview",
    "android:aab": "pnpm dlx eas-cli@18.11.0 build --platform android --profile production",
    "release:local-apk": "tsx scripts/local-apk-release.ts",
    "eas-build-post-install": "pnpm --filter @gaurav-pos/shared build",
    "lint": "pnpm build:shared && tsc --noEmit",
    "test": "vitest run",
    "typecheck": "pnpm build:shared && tsc --noEmit"
  },
  "dependencies": {
    "@gaurav-pos/shared": "workspace:*",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "~55.0.25",
    "expo-asset": "~55.0.17",
    "expo-audio": "55.0.14",
    "expo-camera": "^55.0.18",
    "expo-system-ui": "~55.0.18",
    "react": "^19.2.0",
    "react-native": "^0.83.6",
    "react-native-safe-area-context": "~5.6.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14"
  }
}
