{
  "name": "gaurav-pos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev:cloud": "pnpm --filter @gaurav-pos/cloud-admin dev",
    "dev:hub": "pnpm --filter @gaurav-pos/hub-electron dev",
    "lint": "pnpm -r --if-present lint",
    "test": "vitest run convex/*.test.ts && pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "convex": "^1.38.0",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron-winstaller",
      "esbuild",
      "sharp"
    ]
  }
}
